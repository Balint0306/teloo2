rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Open rules for testing as requested by user.
    // WARNING: Anyone with the project ID can read and write all data.
    match /{document=**} {
      allow read, write: if true;
    }

    // Structured blocks for future hardening
    match /users/{userId} {
      allow read, write: if true;
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }
  }
}
